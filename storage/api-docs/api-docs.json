                    }
                ]
            }
        },
        "/dataprev/propostas/solicitacoes-trabalhador": {
            "get": {
                "tags": [
                    "Propostas CTPS"
                ],
                "summary": "Consulta Solicitações do Trabalhador",
                "description": "Consulta as solicitações de propostas do trabalhador no sistema Dataprev.",
                "operationId": "39bf9afd1ea50b8fb148bc0cd0d417ac",
                "parameters": [
                    {
                        "name": "codigoSolicitante",
                        "in": "query",
                        "description": "Código do solicitante (opcional, usa valor do .env se não informado)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "0526"
                        }
                    },
                    {
                        "name": "idSolicitacaoProposta",
                        "in": "query",
                        "description": "ID específico de uma solicitação de proposta",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 30774347
                        }
                    },
                    {
                        "name": "nroPagina",
                        "in": "query",
                        "description": "Número da página para paginação",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    },
                    {
                        "name": "dataHoraInicio",
                        "in": "query",
                        "description": "Data/hora de início para filtro (formato DDMMYYYYHHmmss)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "dataHoraFim",
                        "in": "query",
                        "description": "Data/hora de fim para filtro (formato DDMMYYYYHHmmss)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Consulta realizada com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "status": {
                                            "type": "integer",
                                            "example": 200
                                        },
                                        "data": {
                                            "description": "Lista de solicitações do trabalhador",
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "idSolicitacao": {
                                                        "description": "ID da solicitação",
                                                        "type": "integer",
                                                        "example": 10000001
                                                    },
                                                    "cpf": {
                                                        "description": "CPF do trabalhador (sem formatação)",
                                                        "type": "integer",
                                                        "example": 12345678900
                                                    },
                                                    "matricula": {
                                                        "description": "Matrícula do trabalhador",
                                                        "type": "string",
                                                        "example": "MAT000001"
                                                    },
                                                    "inscricaoEmpregador": {
                                                        "description": "Tipo de inscrição do empregador",
                                                        "properties": {
                                                            "codigo": {
                                                                "description": "1=CNPJ, 2=CPF",
                                                                "type": "integer",
                                                                "example": 1
                                                            },
                                                            "descricao": {
                                                                "type": "string",
                                                                "example": "CNPJ"
                                                            }
                                                        },
                                                        "type": "object"
                                                    },
                                                    "numeroInscricaoEmpregador": {
                                                        "description": "CNPJ ou CPF do empregador",
                                                        "type": "integer",
                                                        "example": 11222333000100
                                                    },
                                                    "valorLiberado": {
                                                        "description": "Valor liberado para empréstimo",
                                                        "type": "number",
                                                        "format": "float",
                                                        "example": 5000
                                                    },
                                                    "nroParcelas": {
                                                        "description": "Número de parcelas",
                                                        "type": "integer",
                                                        "example": 12
                                                    },
                                                    "dataHoraValidadeSolicitacao": {
                                                        "description": "Validade da solicitação (DDMMYYYYHHmmss)",
                                                        "type": "string",
                                                        "example": "10032026120000"
                                                    },
                                                    "nomeTrabalhador": {
                                                        "description": "Nome completo do trabalhador",
                                                        "type": "string",
                                                        "example": "João da Silva"
                                                    },
                                                    "dataNascimento": {
                                                        "description": "Data de nascimento (DDMMYYYY)",
                                                        "type": "string",
                                                        "example": "15061990"
                                                    },
                                                    "margemDisponivel": {
                                                        "description": "Margem consignável disponível",
                                                        "type": "number",
                                                        "format": "float",
                                                        "example": 3500
                                                    },
                                                    "elegivelEmprestimo": {
                                                        "description": "Se o trabalhador é elegível",
                                                        "type": "boolean",
                                                        "example": true
                                                    },
                                                    "dataAdmissao": {
                                                        "description": "Data de admissão (DDMMYYYY)",
                                                        "type": "string",
                                                        "example": "01032020"
                                                    }
                                                },
                                                "type": "object"
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Não autorizado"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                },
                "security": [
                    {
                        "dataprevAuth": []
                    }
                ]
            }
        },
