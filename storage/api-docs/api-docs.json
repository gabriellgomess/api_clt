{
    "openapi": "3.0.0",
    "info": {
        "title": "Mon-Dataprev e-Consignado API",
        "description": "API de integração Mon-Dataprev com o sistema e-Consignado para operações de consignado CTPS.",
        "contact": {
            "email": "gabriel.gomes@outlook.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api",
            "description": "API Server"
        }
    ],
    "paths": {
        "/dataprev/token": {
            "post": {
                "tags": [
                    "Autenticação"
                ],
                "summary": "Obtém token de acesso OAuth2",
                "description": "Obtém um novo token de acesso OAuth2 da Dataprev. O token é cacheado automaticamente por 55 minutos.",
                "operationId": "10dc8450eb6c3b07ce16b0e959a5e509",
                "parameters": [
                    {
                        "name": "refresh",
                        "in": "query",
                        "description": "Se true, força a renovação do token (ignora cache)",
                        "required": false,
                        "schema": {
                            "type": "boolean",
                            "example": false
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Token obtido com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "token": {
                                            "type": "string",
                                            "example": "eyJ4NXQiOiJxLUZpUURHNEFhWjh2NjN..."
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Token de autenticação do cliente inválido",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Token de autenticação inválido ou não fornecido."
                                        },
                                        "error": {
                                            "type": "string",
                                            "example": "Unauthenticated"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Erro ao obter token OAuth2",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "error": {
                                            "type": "string",
                                            "example": "Não foi possível obter o token de acesso"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "dataprevAuth": []
                    }
                ]
            }
        },
        "/dataprev/propostas/inclusao": {
            "post": {
                "tags": [
                    "Propostas CTPS"
                ],
                "summary": "Inclusão de Proposta CTPS",
                "description": "Realiza a inclusão de uma proposta de consignado no sistema Dataprev e-Consignado.",
                "operationId": "9376416341fd4635019b77eceb070751",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "numeroProposta",
                                    "idSolicitacaoProposta",
                                    "dataHoraValidadeProposta",
                                    "numeroParcelas",
                                    "valorParcela",
                                    "valorLiberado",
                                    "valorEmprestimo",
                                    "valorIOF",
                                    "valorTaxaAnual",
                                    "valorCETAnual",
                                    "valorTaxaMensal",
                                    "valorCETMensal",
                                    "contatos"
                                ],
                                "properties": {
                                    "codigoSolicitante": {
                                        "description": "Código do solicitante (opcional, usa valor do .env se não informado)",
                                        "type": "string",
                                        "example": "0526"
                                    },
                                    "numeroProposta": {
                                        "description": "Número da proposta (12 dígitos)",
                                        "type": "string",
                                        "example": "199912345678"
                                    },
                                    "idSolicitacaoProposta": {
                                        "description": "ID da solicitação da proposta",
                                        "type": "integer",
                                        "example": 30774347
                                    },
                                    "dataHoraValidadeProposta": {
                                        "description": "Data/hora de validade (DDMMYYYYHHmmss)",
                                        "type": "string",
                                        "example": "31012030100000"
                                    },
                                    "numeroParcelas": {
                                        "description": "Número de parcelas",
                                        "type": "integer",
                                        "example": 24
                                    },
                                    "valorParcela": {
                                        "description": "Valor de cada parcela",
                                        "type": "number",
                                        "format": "float",
                                        "example": 200
                                    },
                                    "valorLiberado": {
                                        "description": "Valor liberado ao trabalhador",
                                        "type": "number",
                                        "format": "float",
                                        "example": 1000
                                    },
                                    "valorEmprestimo": {
                                        "description": "Valor total do empréstimo",
                                        "type": "number",
                                        "format": "float",
                                        "example": 1500
                                    },
                                    "valorIOF": {
                                        "description": "Valor do IOF",
                                        "type": "number",
                                        "format": "float",
                                        "example": 0.1
                                    },
                                    "valorTaxaAnual": {
                                        "description": "Taxa de juros anual (%)",
                                        "type": "number",
                                        "format": "float",
                                        "example": 1.2
                                    },
                                    "valorCETAnual": {
                                        "description": "Custo Efetivo Total anual (%)",
                                        "type": "number",
                                        "format": "float",
                                        "example": 1
                                    },
                                    "valorTaxaMensal": {
                                        "description": "Taxa de juros mensal (%)",
                                        "type": "number",
                                        "format": "float",
                                        "example": 0.5
                                    },
                                    "valorCETMensal": {
                                        "description": "Custo Efetivo Total mensal (%)",
                                        "type": "number",
                                        "format": "float",
                                        "example": 0.5
                                    },
                                    "contatos": {
                                        "description": "Lista de contatos do trabalhador",
                                        "type": "array",
                                        "items": {
                                            "required": [
                                                "tipo",
                                                "contato"
                                            ],
                                            "properties": {
                                                "tipo": {
                                                    "description": "Tipo de contato (3=email)",
                                                    "type": "integer",
                                                    "example": 3
                                                },
                                                "contato": {
                                                    "description": "Valor do contato",
                                                    "type": "string",
                                                    "example": "meajuda@monbank.net"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Proposta incluída com sucesso",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "status": {
                                            "type": "integer",
                                            "example": 200
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Não autorizado"
                    },
                    "422": {
                        "description": "Erro de validação dos dados"
                    },
                    "500": {
                        "description": "Erro interno do servidor"
                    }
                },
                "security": [
                    {
                        "dataprevAuth": []
                    }
                ]
            }
        },
